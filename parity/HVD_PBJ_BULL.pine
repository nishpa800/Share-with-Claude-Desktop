bool b2b_en_bull_pbj  = input.bool(true,  "B2B HV+D+PBJ Bull",     group=grp_b2b, inline="b2")
bool b2b_en_bull_pb   = input.bool(true,  "B2B HV+D+PB Bull",      group=grp_b2b, inline="b3")

bool b2b_bull_raw = hvd_fire_bull and nz(hvd_fire_bull[1])
bool b2b_bull_pbj = b2b_bull_raw and (nz(sigBullPBJ[1]) or nz(sigBullPBJ[2]))
bool b2b_bull_pb  = b2b_bull_raw and (nz(sigBullPB[1]) or nz(sigBullPB[2])) and not b2b_bull_pbj
bool b2b_bull_nopb = b2b_bull_raw and not b2b_bull_pbj and not b2b_bull_pb

plotshape(b2b_en_bull     and b2b_bull_nopb and masterGate, "B2B HV+D Bull",      shape.flag, location.belowbar, color.new(#00E676, 0), text="B2B",      textcolor=color.white, size=size.large, offset=-1)
plotshape(b2b_en_bull_pbj and b2b_bull_pbj and masterGate,  "B2B HV+D+PBJ Bull",  shape.flag, location.bottom,   color.new(#FFD700, 0), text="B2B\nPBJ", textcolor=color.white, size=size.huge,  offset=-1)
plotshape(b2b_en_bull_pb  and b2b_bull_pb and masterGate,   "B2B HV+D+PB Bull",   shape.flag, location.bottom,   color.new(#00E5FF, 0), text="B2B\nPB",  textcolor=color.white, size=size.large, offset=-1)

// ============================================================================
// HV+D MOMENTUM CO-OCC — 8 BULL (WAS labels → NOW plotshapes, offset=-1)
// Dynamic 2of3/3of3 component list stays in the alert payload (static plot text).
