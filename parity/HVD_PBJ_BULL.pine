bool co_bull_pbj = hvd_fire_bull and co_en_bullPBJ and nz(sigBullPBJ[1]) and nz(use_any_bull[1])
bool co_bull_pb  = hvd_fire_bull and co_en_bullPB  and nz(sigBullPB[1])  and nz(use_any_bull[1])
bool co_any = co_bull_pbj or co_bull_pb

plotshape(co_bull_pbj and masterGate, "CO: HV+D+PBJ+USE Bull", shape.diamond,    location.top, color.new(#FFD700, 0), text="CO\nPBJ", textcolor=color.white, size=size.huge, offset=-1)
plotshape(co_bull_pb and masterGate,  "CO: HV+D+PB+USE Bull",  shape.triangleup, location.top, color.new(#00E5FF, 0), text="CO\nPB",  textcolor=color.white, size=size.large, offset=-1)

