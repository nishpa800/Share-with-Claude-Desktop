grp_hvdm = "★★★ HV+D MOMENTUM CO-OCC ★★★"
bool en_hvdm_pup_bull  = input.bool(true,  "HV+D+PUP Bull",  group=grp_hvdm, inline="m1")
bool en_hvdm_rvol_bull = input.bool(true,  "HV+D+RVOL Bull", group=grp_hvdm, inline="m2")
bool en_hvdm_cmb_bull  = input.bool(true,  "HV+D+CMB Bull",  group=grp_hvdm, inline="m3")
bool en_hvdm_2of3_bull = input.bool(true,  "2of3 Bull",       group=grp_hvdm, inline="m4")
bool en_hvdm_3of3_bull = input.bool(true,  "3of3 Bull",       group=grp_hvdm, inline="m5")

bool _m_pup1 = nz(sigPUP[1])
bool _m_rv1b = nz(sigBullRVOL1x[1]) or nz(sigGrandSlam[1])
bool _m_cb1b = csNew3_Bull
bool _m_pj1b = nz(sigBullPBJ[1])

bool hvdm_pup_nopbj_b  = hvd_fire_bull and _m_pup1 and not _m_pj1b
bool hvdm_pbjpup_b     = hvd_fire_bull and _m_pj1b and _m_pup1
bool hvdm_rvol_nopbj_b = hvd_fire_bull and _m_rv1b and not _m_pj1b
bool hvdm_pbjrvol_b    = hvd_fire_bull and _m_pj1b and _m_rv1b
bool hvdm_cmb_nopbj_b  = hvd_fire_bull and _m_cb1b and not _m_pj1b
bool hvdm_pbjcmb_b     = hvd_fire_bull and _m_pj1b and _m_cb1b

int  hvdm_b_cnt      = (_m_pup1 ? 1 : 0) + (_m_rv1b ? 1 : 0) + (_m_cb1b ? 1 : 0)
bool hvdm_2of3_b_raw = hvd_fire_bull and _m_pj1b and hvdm_b_cnt >= 2
bool hvdm_3of3_b     = hvd_fire_bull and _m_pj1b and _m_pup1 and _m_rv1b and _m_cb1b

bool hvdm_2of3_b        = hvdm_2of3_b_raw and not hvdm_3of3_b
bool hvdm_vis_pbjpup_b  = hvdm_pbjpup_b  and not hvdm_2of3_b_raw
bool hvdm_vis_pbjrvol_b = hvdm_pbjrvol_b and not hvdm_2of3_b_raw
bool hvdm_vis_pbjcmb_b  = hvdm_pbjcmb_b  and not hvdm_2of3_b_raw

plotshape(en_hvdm_pup_bull  and hvdm_pup_nopbj_b  and masterGate, "HV+D+PUP Bull",      shape.triangleup, location.top, color.new(#00E676, 0), text="HVD\nPUP",       textcolor=color.white, size=size.normal, offset=-1)
plotshape(en_hvdm_rvol_bull and hvdm_rvol_nopbj_b and masterGate, "HV+D+RVOL Bull",     shape.triangleup, location.top, color.new(#00BCD4, 0), text="HVD\nRVOL",      textcolor=color.white, size=size.normal, offset=-1)
plotshape(en_hvdm_cmb_bull  and hvdm_cmb_nopbj_b  and masterGate, "HV+D+CMB Bull",      shape.triangleup, location.top, color.new(#43A047, 0), text="HVD\nCMB",       textcolor=color.white, size=size.normal, offset=-1)
plotshape(en_hvdm_pup_bull  and hvdm_vis_pbjpup_b  and masterGate, "HV+D+PBJ+PUP Bull",  shape.diamond,   location.top, color.new(#FFD700, 0), text="HVD+PBJ\nPUP",   textcolor=color.white, size=size.large, offset=-1)
plotshape(en_hvdm_rvol_bull and hvdm_vis_pbjrvol_b and masterGate, "HV+D+PBJ+RVOL Bull", shape.diamond,   location.top, color.new(#E040FB, 0), text="HVD+PBJ\nRVOL",  textcolor=color.white, size=size.large, offset=-1)
plotshape(en_hvdm_cmb_bull  and hvdm_vis_pbjcmb_b  and masterGate, "HV+D+PBJ+CMB Bull",  shape.diamond,   location.top, color.new(#7C4DFF, 0), text="HVD+PBJ\nCMB",   textcolor=color.white, size=size.large, offset=-1)
plotshape(en_hvdm_2of3_bull and hvdm_2of3_b and masterGate,        "HV+D+PBJ 2of3 Bull", shape.labelup,   location.top, color.new(#FF6D00, 0), text="HVD+PBJ\n2of3",  textcolor=color.white, size=size.large, offset=-1)
plotshape(en_hvdm_3of3_bull and hvdm_3of3_b and masterGate,        "HV+D+PBJ 3of3 Bull", shape.labelup,   location.top, color.new(#FFD700, 0), text="HVD+PBJ\n3of3",  textcolor=color.black, size=size.huge, offset=-1)

// ============================================================================
// ALERTS — BULL (1:1 with the 38 plotshapes)
// ============================================================================
if en_hvd_bull and hvd_fire_bull and masterGate and not hvd_pbj_bull and not hvd_pb_bull
    alert("BULL | " + _FIRST + " | HV+D", alert.freq_once_per_bar_close)
if en_hvd_pbj_bull and hvd_pbj_bull and masterGate
    alert("BULL | " + _FIRST + " | HV+D+PBJ", alert.freq_once_per_bar_close)
if en_hvd_pb_bull and hvd_pb_bull and masterGate
    alert("BULL | " + _FIRST + " | HV+D+PB", alert.freq_once_per_bar_close)

if b2b_en_bull and b2b_bull_nopb and masterGate
    alert("BULL | " + _FIRST + " | B2B-HVD", alert.freq_once_per_bar_close)
if b2b_en_bull_pbj and b2b_bull_pbj and masterGate
    alert("BULL | " + _FIRST + " | B2B-HVD+PBJ", alert.freq_once_per_bar_close)
if b2b_en_bull_pb and b2b_bull_pb and masterGate
    alert("BULL | " + _FIRST + " | B2B-HVD+PB", alert.freq_once_per_bar_close)

if en_hvdm_pup_bull and hvdm_pup_nopbj_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PUP", alert.freq_once_per_bar_close)
if en_hvdm_pup_bull and hvdm_vis_pbjpup_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PBJ+PUP", alert.freq_once_per_bar_close)
if en_hvdm_rvol_bull and hvdm_rvol_nopbj_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+RVOL", alert.freq_once_per_bar_close)
if en_hvdm_rvol_bull and hvdm_vis_pbjrvol_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PBJ+RVOL", alert.freq_once_per_bar_close)
if en_hvdm_cmb_bull and hvdm_cmb_nopbj_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+COMBO", alert.freq_once_per_bar_close)
if en_hvdm_cmb_bull and hvdm_vis_pbjcmb_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PBJ+COMBO", alert.freq_once_per_bar_close)
if en_hvdm_2of3_bull and hvdm_2of3_b and masterGate
    string _2ba = ""
    if _m_pup1
        _2ba := f_add(_2ba, "PUP")
    if _m_rv1b
        _2ba := f_add(_2ba, "RVOL")
    if _m_cb1b
        _2ba := f_add(_2ba, "CMB")
    alert("BULL | " + _FIRST + " | HVD+PBJ 2of3[" + _2ba + "]", alert.freq_once_per_bar_close)
if en_hvdm_3of3_bull and hvdm_3of3_b and masterGate
    alert("BULL | " + _FIRST + " | HVD+PBJ 3of3[PUP+RVOL+CMB]", alert.freq_once_per_bar_close)

if co_any
    string co_pb_type = co_bull_pbj ? "PBJ" : "PB"
    alert("BULL | " + _FIRST + " | CO " + co_pb_type, alert.freq_once_per_bar_close)

// === USE AGGREGATOR ALERT (bull) ===
f_agg_bull() =>
    string _s=""
    if fire_SDuperBull
        _s:=f_add(_s,"SUPER DUPER")
    if fire_SuperBull and not fire_SDuperBull
        _s:=f_add(_s,"SUPER")
    if fire_HWBull
        _s:=f_add(_s,"HW")
    if fire_BullFloor
        _s:=f_add(_s,"FLOOR")
    if fire_Bull2ndFloor
        _s:=f_add(_s,"2F")
    if fire_BullUUUU
        _s:=f_add(_s,"UUUU")
    if fire_BullUUU
        _s:=f_add(_s,"UUU")
    if fire_BullUU
        _s:=f_add(_s,"UU")
    if fire_AlphaStrikeB
        _s:=f_add(_s,"A-STRIKE")
    if fire_FoxtrotB
        _s:=f_add(_s,"FOX")
    if fire_OmegaLongA
        _s:=f_add(_s,"OMEGA")
    if fire_ODBull
        _s:=f_add(_s,"OD")
    if fire_DispConsBull2
        _s:=f_add(_s,"D2+")
    if fire_DispConsBull3
        _s:=f_add(_s,"D3+")
    if fire_GolfBull
        _s:=f_add(_s,"GOLF")
    if fire_PAFBull
        _s:=f_add(_s,"PAF")
    if fire_CS1B
        _s:=f_add(_s,"FVG")
    if fire_CS2B
        _s:=f_add(_s,"MAT")
    if fire_CS3B
        _s:=f_add(_s,"COMBO")
    if fire_CCBull
        _s:=f_add(_s,"CC")
    if fire_LSCBull
        _s:=f_add(_s,"LSC")
    _s

if conf
    string bs=f_agg_bull()
    if en_aggregate and str.length(bs)>0
        alert("BULL | " + _FIRST + " | " + bs, alert.freq_once_per_bar_close)
    if show_Nagasaki and sigNagasaki and masterGate
        string nd=nag_dir_bull and nag_dir_bear?"BOTH":nag_dir_bull?"BULL":nag_dir_bear?"BEAR":"NEUTRAL"
        alert("BULL | " + _FIRST + " | NAGASAKI " + nd, alert.freq_once_per_bar_close)