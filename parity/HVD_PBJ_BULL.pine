plotshape(en_hvd_pbj_bull and hvd_pbj_bull and masterGate, "PBJ Bull", shape.diamond,  location.top, color.new(color.yellow, 25), size=size.normal, text="HV+D\nPBJ", textcolor=color.white, offset=-1)

// USE bull plotshapes (21)
plotshape(fire_BullUUUU,"Bull UUUU",shape.labelup,location.top,color.new(#00FF00,0),text="UUUU",textcolor=color.white,size=size.large,offset=-1)
plotshape(fire_BullUUU,"Bull UUU",shape.labelup,location.abovebar,color.new(#76FF03,0),text="UUU",textcolor=color.white,size=size.normal,offset=-1)
plotshape(fire_BullUU,"Bull UU",shape.labelup,location.belowbar,color.new(#A5D6A7,0),text="UU",textcolor=color.white,size=size.small,offset=-1)
